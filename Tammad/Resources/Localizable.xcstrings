    "SSO Login Instructions" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1. Öffnen Sie Ihre Zammad-Instanz in einem Webbrowser (z. B. Safari oder Chrome).\n2. Melden Sie sich mit dem Single Sign-On (SSO) Ihres Unternehmens an.\n3. Klicken Sie auf Ihr Profilsymbol (oben rechts) und gehen Sie zu „Profil“ oder „Einstellungen“.\n4. Unter „Token-Zugriff“ oder „API-Token“ erstellen Sie einen neuen Token oder kopieren einen bestehenden.\n5. Fügen Sie den Token unten ein und tippen Sie auf Anmelden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1. Open your Zammad instance in a web browser (e.g. Safari or Chrome).\n2. Log in using your company's Single Sign-On (SSO).\n3. Click your profile icon (top right) and go to \"Profile\" or \"Preferences\".\n4. Under \"Token Access\" or \"API Tokens\", create a new token or copy an existing one.\n5. Paste the token below and tap Login."
          }
        }
      }
    },
    "SSO Login Instructions Title" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "So verbinden Sie sich mit SSO"
